# Copy this file to .env and fill only the keys you use.

# Project root. Usually optional because project_path.py auto-detects it.
SOCCERAGENT_HOME=

# Agent / planner LLM. Use either OpenAI-compatible GPT or DeepSeek-compatible API.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
AGENT_MODEL_NAME=gpt-5.4
REASONING_EFFORT=medium
VLM_REASONING_EFFORT=low
CAMERA_DETECTION_VLM_REASONING_EFFORT=none
GROUNDING_COUNT_REASONING_EFFORT=high
VERBOSITY=medium
AGENT_TEMPERATURE=0.0
RETRIEVE_TEMPERATURE=0.0
CLOSEQA_TEMPERATURE=0.0
CLOSEQA_VERBOSITY=low
DEEPSEEK_THINKING_MODE=auto

# Local vision model for visual tools.
# VISION_BACKEND=qwen
# VLM_MODEL_NAME=./models/Qwen3-VL-32B-Instruct
VISION_BACKEND=api
VLM_MODEL_NAME=gpt-5.4
VLM_RESERVE_GPU0=0
VLM_ENABLE_THINKING=0
VLM_USE_AIR_FRAME_SELECTION=0
VLM_VIDEO_FPS=4.0
VLM_MAX_NEW_TOKENS=8000
VLM_API_VIDEO_MIN_FRAMES=4
VLM_API_VIDEO_MAX_FRAMES=32
VLM_GPU0_MAX_GIB=0
VLM_GPU1_MAX_GIB=0
VLM_GPU2_MAX_GIB=48
VLM_GPU3_MAX_GIB=48
VLM_GPU4_MAX_GIB=48
VLM_GPU5_MAX_GIB=48

# Camera/video visual tool settings.
JERSEY_COLOR_VLM_FPS=4.0
CAMERA_DETECTION_VIDEO_MODE=clip
CAMERA_DETECTION_FRAME_STRIDE=10
CAMERA_DETECTION_CLIP_MAX_FRAMES=32

# Improved replay grounding. This submission intentionally uses local Qwen3-VL-Embedding.
REPLAY_GROUNDING_EMBED_BACKEND=qwen
QWEN3_VL_EMBED_ROOT=./third_party/Qwen3-VL-Embedding
QWEN3_VL_EMBED_MODEL=./models/Qwen3-VL-Embedding-8B
QWEN3_VL_EMBED_DTYPE=bfloat16
QWEN3_VL_EMBED_FPS=10
QWEN3_VL_EMBED_MAX_FRAMES=150
QWEN3_VL_EMBED_MAX_LENGTH=81920
QWEN3_VL_EMBED_DEVICE=cuda:1

# Tool/device placement.
FRAME_SELECTION_USE_GPU=1
FRAME_SELECTION_DEVICE=cuda:0
UNISOCCER_DEVICE=cuda:0
JNR_DEVICE=cuda:1
SHOT_CHANGE_CLIP_DEVICE=cpu
SHOT_CHANGE_FORCE_FALLBACK=1
GDINO_DEVICE=cuda:0
EASYOCR_USE_GPU=1
