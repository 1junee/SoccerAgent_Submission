# Copy this file to .env and fill only the keys you use.

# Agent / planner LLM. OpenAI-compatible GPT-5.x is the default path used here.
OPENAI_API_KEY=
AGENT_MODEL_NAME=gpt-5.4
REASONING_EFFORT=medium
VERBOSITY=medium
AGENT_TEMPERATURE=0.0
CLOSEQA_TEMPERATURE=0.0
CLOSEQA_VERBOSITY=low

# Local vision model for visual tools.
# VISION_BACKEND=qwen
VISION_BACKEND=api
# VLM_MODEL_NAME=./models/Qwen3-VL-32B-Instruct
VLM_MODEL_NAME=gpt-5.4
VLM_RESERVE_GPU0=0
VLM_ENABLE_THINKING=0
VLM_USE_AIR_FRAME_SELECTION=0
VLM_VIDEO_FPS=4.0
VLM_MAX_NEW_TOKENS=8000
VLM_GPU0_MAX_GIB=0
VLM_GPU1_MAX_GIB=0
VLM_GPU2_MAX_GIB=48
VLM_GPU3_MAX_GIB=48
VLM_GPU4_MAX_GIB=48
VLM_GPU5_MAX_GIB=48

# Improved replay grounding. This submission intentionally uses local Qwen3-VL-Embedding.
REPLAY_GROUNDING_EMBED_BACKEND=qwen
QWEN3_VL_EMBED_ROOT=./third_party/Qwen3-VL-Embedding
QWEN3_VL_EMBED_MODEL=./models/Qwen3-VL-Embedding-8B
QWEN3_VL_EMBED_DTYPE=bfloat16
QWEN3_VL_EMBED_FPS=10
QWEN3_VL_EMBED_MAX_FRAMES=150
QWEN3_VL_EMBED_MAX_LENGTH=81920
QWEN3_VL_EMBED_DEVICE=cuda:1

# Tool/device placement.
FRAME_SELECTION_USE_GPU=1
FRAME_SELECTION_DEVICE=cuda:0
UNISOCCER_DEVICE=cuda:0
JNR_DEVICE=cuda:2
SHOT_CHANGE_CLIP_DEVICE=cpu
GDINO_DEVICE=cuda:0
EASYOCR_USE_GPU=1
